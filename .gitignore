# macOS
.DS_Store

# Xcode のユーザー状態(個人環境依存なので共有しない)
xcuserdata/
*.xcuserstate

# ビルド生成物
build/
DerivedData/
*.xcresult

# Swift Package Manager
.swiftpm/
.build/

# モデル成果物(コミットしない。scripts/ から再生成可能に保つ — CLAUDE.md の制約)
*.mlpackage
*.mlmodelc
# トークナイザ成果物も同様に scripts/install_model.sh で再配置する
SemanticNotes/Resources/tokenizer.json
SemanticNotes/Resources/tokenizer_config.json
SemanticNotes/Resources/special_tokens_map.json

# Python(scripts/ のモデル変換用)
scripts/.venv/
scripts/output/
__pycache__/
*.pyc
